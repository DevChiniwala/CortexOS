# CortexOS Environment Variables
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (required for LLM extraction, synthesis, and embeddings)
# Get a free key at: https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=your-gemini-api-key-here

# Tavily API Key (required for Grounded Web Research)
# Get a free key at: https://tavily.com (1000 credits/month, no card)
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Apollo API Key (optional, for Data Enrichment)
APOLLO_API_KEY=your-apollo-api-key-here
