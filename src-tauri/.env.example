# CortexOS Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API Key (required for the Live Agent Engine)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Apollo API Key (required for Data Enrichment)
APOLLO_API_KEY=your-apollo-api-key-here

# Tavily API Key (required for Grounded Web Research)
TAVILY_API_KEY=tvly-your-tavily-api-key-here
